# Firebase Functions — local emulator secrets template
# Copy to functions/.secret.local and fill in values.
# Never commit functions/.secret.local — it is gitignored.
#
# Production: set each value via Firebase Secret Manager before deploying:
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
#   firebase functions:secrets:set STRIPE_PRICE_PARENT_MONTHLY
#   firebase functions:secrets:set STRIPE_PRICE_PARENT_YEARLY
#   firebase functions:secrets:set STRIPE_PRICE_PARENT_LIFETIME
#   firebase functions:secrets:set STRIPE_PRICE_TEACHER_MONTHLY
#   firebase functions:secrets:set STRIPE_PRICE_TEACHER_YEARLY
#   firebase functions:secrets:set STRIPE_PRICE_TEACHER_LIFETIME
#
# Local emulator: create functions/.secret.local with the contents below.
# Use test keys (sk_test_...) and test price IDs (price_...) locally.
# Use the webhook secret printed by `stripe listen` (whsec_...).

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PARENT_MONTHLY=price_...
STRIPE_PRICE_PARENT_YEARLY=price_...
STRIPE_PRICE_PARENT_LIFETIME=price_...
STRIPE_PRICE_TEACHER_MONTHLY=price_...
STRIPE_PRICE_TEACHER_YEARLY=price_...
STRIPE_PRICE_TEACHER_LIFETIME=price_...
