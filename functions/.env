# Firebase Functions environment variables
# Copy to functions/.env for local emulator use.
#
#   Set via Secret Manager before deploying:
#     firebase functions:secrets:set STRIPE_SECRET_KEY
#     firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
#   For emulator, create functions/.secret.local:
#     STRIPE_SECRET_KEY=sk_test_...
#     STRIPE_WEBHOOK_SECRET=whsec_...
#
# NON-SECRET STRIPE PRICE IDs (safe to commit per environment):
# Create these products in the Stripe dashboard, then paste the Price IDs below.
#
#   Parent plans:
STRIPE_PRICE_PARENT_MONTHLY=price_1TG2hbBV69Xwe87vDmzPGT7D
STRIPE_PRICE_PARENT_YEARLY=price_1TG2iuBV69Xwe87vErwsNLq2
STRIPE_PRICE_PARENT_LIFETIME=price_1TG2k4BV69Xwe87vVSr2qZux
#
#   Teacher plans:
