rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function hasProfileClaim() {
      return request.auth != null
        && request.auth.token is map
        && request.auth.token.keys().hasAny(['profileId']);
    }

    function isProfileSession() {
      return hasProfileClaim();
    }

    function profileClaim() {
      return hasProfileClaim() ? request.auth.token.profileId : null;
    }

    function isTeacher(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && get(/databases/$(database)/documents/users/$(userId)).data.userRole == 'teacher';
    }

    // Returns true when the user has an active premium subscription.
    function isPremium(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.subscriptionStatus == 'premium';
    }

    // The set of pack keys available to free users.
    function freePacks() {
      return ['mul_36', 'add_20', 'sub_20'];
    }

    // Returns true when both the activePack and every pack in enabledPacks are free.
    function packsAreFree(enabledPacks, activePack) {
      return activePack in freePacks() && enabledPacks.hasOnly(freePacks());
    }

    // Returns true when the pack fields being written are permitted for the user's tier.
    function packUpdateAllowed(userId, incoming, existing) {
      return isPremium(userId)
        || !incoming.diff(existing).affectedKeys().hasAny(['activePack', 'enabledPacks'])
        || packsAreFree(
             incoming.get('enabledPacks', ['mul_36']),
             incoming.get('activePack', 'mul_36')
           );
    }

    // Fields the client must never write to the user doc.
    // Mirrors ClientUpdatableUserAccount in dataModels.ts — keep in sync.
    function clientImmutableWriteBlocked(incoming, existing) {
      return !incoming.diff(existing).affectedKeys().hasAny([
        // Billing & entitlements — written only by Cloud Functions
        'subscriptionStatus', 'planType', 'billingPeriod',
        'stripeCustomerId', 'stripeSubscriptionId', 'stripePriceId',
        'promoCodeId', 'premiumExpiresAt',
        // classroomCount is server-maintained (Cloud Function trigger, PR 2).
        // Blocking client writes here prevents free-tier classroom-limit bypass.
        'classroomCount',
        // Server-set identity fields
        'createdAt', 'primaryProfileId'
        // lastLogin and lastSignInMethod are intentionally NOT listed here because
        // UserProvider legitimately writes them on auth state change.
      ]);
    }

    // User root doc
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // User docs are created server-side (Auth onCreate Cloud Function).
      // Disallow client-side creates to prevent partial/incorrect user docs.
      allow create: if false;
      allow delete: if request.auth != null && request.auth.uid == userId
        && !isProfileSession();

      allow update: if request.auth != null
        && request.auth.uid == userId
        && !isProfileSession()
        && clientImmutableWriteBlocked(request.resource.data, resource.data);
    }

    // Profiles
    match /users/{userId}/profiles/{profileId} {
      allow read: if request.auth != null
        && request.auth.uid == userId
        && (!isProfileSession() || profileClaim() == profileId);

      // Profile docs are created server-side to enforce unique login names.
      allow create: if false;

      allow update: if request.auth != null
        && request.auth.uid == userId
        && (!isProfileSession() || profileClaim() == profileId)
        // Prevent clients from enabling PIN or changing loginName once enabled.
        && (resource.data.pinEnabled == true
            ? request.resource.data.pinEnabled == true
            : request.resource.data.pinEnabled != true)
        && request.resource.data.loginName == resource.data.loginName
        // Free users may only assign free packs.
        && packUpdateAllowed(userId, request.resource.data, resource.data);

      allow delete: if request.auth != null
        && request.auth.uid == userId
        && !isProfileSession();
    }

    match /users/{userId}/profiles/{profileId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && (!isProfileSession() || profileClaim() == profileId);
    }

    // Teacher-only classrooms
    match /users/{userId}/classrooms/{classId} {
      allow read: if isTeacher(userId) && !isProfileSession();

      // Free-tier classroom count limit (max 1) is enforced server-side via a
      // Cloud Function trigger that maintains classroomCount on the user doc (PR 2).
      // Client writes to classroomCount are blocked above, so the stored value is
      // trustworthy once Cloud Functions maintain it.
      allow create: if isTeacher(userId) && !isProfileSession()
        // Free teachers may only set free packs as class defaults.
        && (isPremium(userId)
            || packsAreFree(
                 request.resource.data.get('defaultEnabledPacks', ['mul_36']),
                 request.resource.data.get('defaultActivePack', 'mul_36')
               ));

      allow update: if isTeacher(userId) && !isProfileSession()
        // Free teachers may not switch class defaults to premium packs.
        && (isPremium(userId)
            || !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['defaultEnabledPacks', 'defaultActivePack'])
            || packsAreFree(
                 request.resource.data.get('defaultEnabledPacks', ['mul_36']),
                 request.resource.data.get('defaultActivePack', 'mul_36')
               ));

      allow delete: if isTeacher(userId) && !isProfileSession();

      match /roster/{profileId} {
        allow read: if isTeacher(userId) && !isProfileSession();

        // Free-tier roster size limit (max 25) is enforced server-side via Cloud
        // Functions (PR 2). rosterCount on the classroom doc is client-maintained
        // and not a trustworthy authorization source, so the count limit is not
        // enforced here. Pack entitlement checks below are reliable because pack
        // keys are static, known values that don't depend on a client counter.
        allow create: if isTeacher(userId) && !isProfileSession()
          // Free teachers may only assign free packs to learners.
          && (isPremium(userId)
              || packsAreFree(
                   request.resource.data.get('enabledPacks', ['mul_36']),
                   request.resource.data.get('activePack', 'mul_36')
                 ));

        allow update: if isTeacher(userId) && !isProfileSession()
          // Free teachers may not switch learners to premium packs.
          && (isPremium(userId)
              || !request.resource.data.diff(resource.data).affectedKeys()
                   .hasAny(['enabledPacks', 'activePack'])
              || packsAreFree(
                   request.resource.data.get('enabledPacks', ['mul_36']),
                   request.resource.data.get('activePack', 'mul_36')
                 ));

        allow delete: if isTeacher(userId) && !isProfileSession();
      }
    }

    // Any other subcollections under the user (account-only access)
    match /users/{userId}/{collection}/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && !isProfileSession()
        // Exclude classrooms so only the teacher-only rule applies there.
        && collection != 'classrooms';
    }

    match /users/{userId}/{collection}/{docId}/{rest=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && !isProfileSession()
        // Exclude classrooms so only the teacher-only rule applies there.
        && collection != 'classrooms';
    }

    // Feedback (write-only from client)
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.type in ['bug', 'confusing', 'feature', 'pricing', 'other']
        && request.resource.data.summary is string
        && request.resource.data.summary.size() > 0
        && request.resource.data.summary.size() <= 140
        // keep payload bounded
        && (!('details' in request.resource.data) || request.resource.data.details == null || request.resource.data.details.size() <= 4000);

      allow read, update, delete: if false;
    }

    match /profileIndex/{loginNameKey} {
      allow read, write: if false;
    }

    match /profileSecrets/{profileId} {
      allow read, write: if false;
    }

    // Promo codes — read and written only by Cloud Functions.
    // Clients redeem via the redeemPromoCode callable; no direct access.
    match /promoCodes/{code} {
      allow read, write: if false;
    }
  }
}
