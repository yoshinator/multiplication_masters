rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function hasProfileClaim() {
      return request.auth != null
        && request.auth.token is map
        && request.auth.token.keys().hasAny(['profileId']);
    }

    function isProfileSession() {
      return hasProfileClaim();
    }

    function profileClaim() {
      return hasProfileClaim() ? request.auth.token.profileId : null;
    }

    function isTeacher(userId) {
      return request.auth != null
        && request.auth.uid == userId
        && get(/databases/$(database)/documents/users/$(userId)).data.userRole == 'teacher';
    }

    // Returns true when the user has an active premium subscription.
    function isPremium(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.subscriptionStatus == 'premium';
    }

    // The set of pack keys available to free users.
    function freePacks() {
      return ['mul_36', 'add_20', 'sub_20'];
    }

    // Returns true when both the activePack and every pack in enabledPacks are free.
    function packsAreFree(enabledPacks, activePack) {
      return activePack in freePacks() && enabledPacks.hasOnly(freePacks());
    }

    // Returns true when the pack fields being written are permitted for the user's tier.
    // A write is permitted when:
    //   - the user is premium, OR
    //   - the pack-related fields are not changing, OR
    //   - the new pack values are restricted to the free set.
    function packUpdateAllowed(userId, incoming, existing) {
      return isPremium(userId)
        || !incoming.diff(existing).affectedKeys().hasAny(['activePack', 'enabledPacks'])
        || packsAreFree(
             incoming.get('enabledPacks', ['mul_36']),
             incoming.get('activePack', 'mul_36')
           );
    }

    // Server-managed billing/entitlement fields that clients must not write directly.
    // Note: classroomCount is intentionally excluded — clients update it in a batch
    // alongside classroom creates/deletes; rules enforce the ±1 invariant below.
    function clientBillingWriteBlocked(incoming, existing) {
      return !incoming.diff(existing).affectedKeys().hasAny([
        'subscriptionStatus', 'planType', 'billingPeriod',
        'stripeCustomerId', 'stripeSubscriptionId', 'stripePriceId',
        'promoCodeId', 'premiumExpiresAt'
      ]);
    }

    // User root doc
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // User docs are created server-side (Auth onCreate Cloud Function).
      // Disallow client-side creates to prevent partial/incorrect user docs.
      allow create: if false;
      allow delete: if request.auth != null && request.auth.uid == userId
        && !isProfileSession();

      allow update: if request.auth != null
        && request.auth.uid == userId
        && !isProfileSession()
        // Block client writes to server-managed billing and entitlement fields.
        && clientBillingWriteBlocked(request.resource.data, resource.data)
        // classroomCount may only change by ±1. Clients must update it in the same
        // batch as a classroom create or delete; getAfter() checks in those rules
        // validate that the counter is consistent with the actual operation.
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['classroomCount'])
          || request.resource.data.classroomCount == resource.data.get('classroomCount', 0) + 1
          || request.resource.data.classroomCount == resource.data.get('classroomCount', 0) - 1
        );
    }

    // Profiles
    match /users/{userId}/profiles/{profileId} {
      allow read: if request.auth != null
        && request.auth.uid == userId
        && (!isProfileSession() || profileClaim() == profileId);

      // Profile docs are created server-side to enforce unique login names.
      allow create: if false;

      allow update: if request.auth != null
        && request.auth.uid == userId
        && (!isProfileSession() || profileClaim() == profileId)
        // Prevent clients from enabling PIN or changing loginName once enabled.
        && (resource.data.pinEnabled == true
            ? request.resource.data.pinEnabled == true
            : request.resource.data.pinEnabled != true)
        && request.resource.data.loginName == resource.data.loginName
        // Free users may only assign free packs.
        && packUpdateAllowed(userId, request.resource.data, resource.data);

      allow delete: if request.auth != null
        && request.auth.uid == userId
        && !isProfileSession();
    }

    match /users/{userId}/profiles/{profileId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && (!isProfileSession() || profileClaim() == profileId);
    }

    // Teacher-only classrooms
    match /users/{userId}/classrooms/{classId} {
      allow read: if isTeacher(userId) && !isProfileSession();

      // Free teachers are limited to 1 classroom (FREE_TEACHER_MAX_CLASSROOMS).
      // Enforcement uses getAfter() so the limit holds even when multiple classrooms
      // are attempted in a single batch: every create in the batch sees the same
      // final classroomCount, so two creates with classroomCount += 2 fail the
      // exact-increment check. Clients must batch this create with a
      // classroomCount: increment(1) update on the user doc.
      allow create: if isTeacher(userId) && !isProfileSession()
        && (isPremium(userId) || (
          // Post-write classroomCount must not exceed the free-tier limit.
          getAfter(/databases/$(database)/documents/users/$(userId)).data.get('classroomCount', 0) <= 1
          // Exactly one classroom is being created (not a multi-create batch).
          && getAfter(/databases/$(database)/documents/users/$(userId)).data.get('classroomCount', 0)
             == get(/databases/$(database)/documents/users/$(userId)).data.get('classroomCount', 0) + 1
        ))
        // Free teachers may only set free packs as class defaults.
        && (isPremium(userId)
            || packsAreFree(
                 request.resource.data.get('defaultEnabledPacks', ['mul_36']),
                 request.resource.data.get('defaultActivePack', 'mul_36')
               ));

      allow update: if isTeacher(userId) && !isProfileSession()
        // Free teachers may not switch class defaults to premium packs.
        && (isPremium(userId)
            || !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['defaultEnabledPacks', 'defaultActivePack'])
            || packsAreFree(
                 request.resource.data.get('defaultEnabledPacks', ['mul_36']),
                 request.resource.data.get('defaultActivePack', 'mul_36')
               ))
        // rosterCount must not decrease via a direct classroom update.
        // Decrements are only valid when a roster entry is deleted in the same batch,
        // which is enforced by the getAfter() check in the roster delete rule.
        // This prevents a free teacher from resetting rosterCount to bypass the cap.
        && request.resource.data.get('rosterCount', 0)
           >= resource.data.get('rosterCount', 0);

      // Clients must batch classroom deletion with a classroomCount: increment(-1)
      // update on the user doc. The getAfter() check validates consistency.
      allow delete: if isTeacher(userId) && !isProfileSession()
        && getAfter(/databases/$(database)/documents/users/$(userId)).data.get('classroomCount', 0)
           == get(/databases/$(database)/documents/users/$(userId)).data.get('classroomCount', 0) - 1;

      match /roster/{profileId} {
        allow read: if isTeacher(userId) && !isProfileSession();

        // Free teachers are limited to 25 roster entries (FREE_TEACHER_MAX_ROSTER).
        // Enforcement uses getAfter() on the classroom doc so the limit is based on
        // the post-batch rosterCount, not the pre-batch value. Clients must update
        // rosterCount: increment(N) on the classroom doc in the same batch.
        //
        // Note: rosterCount is maintained by the client in batches alongside roster
        // creates/deletes. Direct rosterCount decrements in classroom updates are
        // blocked (see classroom update rule), so decrements only arrive via the
        // roster delete rule below. An attacker cannot reset rosterCount to zero
        // to bypass the cap because classroom UPDATE blocks any decrease to rosterCount.
        // Full server-side integrity (e.g., verifying rosterCount matches actual doc count)
        // is deferred to Cloud Functions in PR 2.
        allow create: if isTeacher(userId) && !isProfileSession()
          // rosterCount must increase in the same batch (client must increment it).
          && getAfter(/databases/$(database)/documents/users/$(userId)/classrooms/$(classId)).data.get('rosterCount', 0)
             > get(/databases/$(database)/documents/users/$(userId)/classrooms/$(classId)).data.get('rosterCount', 0)
          // Post-write rosterCount must not exceed the free-tier cap.
          && (isPremium(userId)
              || getAfter(/databases/$(database)/documents/users/$(userId)/classrooms/$(classId)).data.get('rosterCount', 0) <= 25)
          // Free teachers may only assign free packs to learners.
          && (isPremium(userId)
              || packsAreFree(
                   request.resource.data.get('enabledPacks', ['mul_36']),
                   request.resource.data.get('activePack', 'mul_36')
                 ));

        allow update: if isTeacher(userId) && !isProfileSession()
          // Free teachers may not switch learners to premium packs.
          && (isPremium(userId)
              || !request.resource.data.diff(resource.data).affectedKeys()
                   .hasAny(['enabledPacks', 'activePack'])
              || packsAreFree(
                   request.resource.data.get('enabledPacks', ['mul_36']),
                   request.resource.data.get('activePack', 'mul_36')
                 ));

        // Clients must batch roster deletion with a rosterCount: increment(-1)
        // update on the classroom doc. The getAfter() check validates consistency.
        allow delete: if isTeacher(userId) && !isProfileSession()
          && getAfter(/databases/$(database)/documents/users/$(userId)/classrooms/$(classId)).data.get('rosterCount', 0)
             < get(/databases/$(database)/documents/users/$(userId)/classrooms/$(classId)).data.get('rosterCount', 0);
      }
    }

    // Any other subcollections under the user (account-only access)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId
        && !isProfileSession()
        // Exclude classrooms so only the teacher-only rule applies there.
        && !request.path.matches("/databases/$(database)/documents/users/$(userId)/classrooms/{classId}")
        && !request.path.matches("/databases/$(database)/documents/users/$(userId)/classrooms/{classId}/{document=**}");
    }

    // Feedback (write-only from client)
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.type in ['bug', 'confusing', 'feature', 'pricing', 'other']
        && request.resource.data.summary is string
        && request.resource.data.summary.size() > 0
        && request.resource.data.summary.size() <= 140
        // keep payload bounded
        && (!('details' in request.resource.data) || request.resource.data.details == null || request.resource.data.details.size() <= 4000);

      allow read, update, delete: if false;
    }

    match /profileIndex/{loginNameKey} {
      allow read, write: if false;
    }

    match /profileSecrets/{profileId} {
      allow read, write: if false;
    }
  }
}
